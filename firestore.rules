rules_version = '2';

// ============================================================
//  Regras de PRODUÇÃO — sem login.
//  Qualquer pessoa com o app (o ID do projeto é público) pode ler
//  e escrever, MAS apenas nas coleções usadas pelo app e respeitando
//  um formato mínimo. Isso evita:
//   - a expiração automática do "modo teste";
//   - criação de coleções/lixo aleatório no banco;
//   - documentos gigantes que estourariam a cota.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // Roteiro dos destinos: { nome: string, busca: string?, dias: list }
    match /destinos/{id} {
      allow read: if true;
      allow write: if request.resource.data.nome is string
                   && request.resource.data.dias is list
                   && request.resource.data.dias.size() <= 60;
    }

    // Configurações do app, ex.: config/levar = { itens: list }
    match /config/{doc} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['itens'])
                   && request.resource.data.itens is list
                   && request.resource.data.itens.size() <= 200;
    }

    // Tudo o que não estiver acima é bloqueado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
